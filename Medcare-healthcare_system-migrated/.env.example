# Copy this to .env and fill in your values
# Never commit .env to version control

# Database password for PostgreSQL (production)
DB_PASSWORD=MedCarePass123

# JWT signing secret — MUST be at least 32 characters in production
JWT_SECRET=ChangeThisToASecureRandomStringInProduction32Chars!

# Frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:4200
